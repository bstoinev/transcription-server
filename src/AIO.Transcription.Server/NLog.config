<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="Warn"
      internalLogFile="${gdc:item=LogRoot}/nlog-internal.log">
  <variable name="logDir" value="${gdc:item=LogRoot}" />
  <variable name="layout" value="${longdate}|${uppercase:${level}}|${logger}|${message}${onexception:inner=|${exception:format=ToString}}" />

  <targets async="true">
    <target xsi:type="Console"
            name="console"
            layout="${var:layout}" />

    <target xsi:type="File"
            name="file"
            fileName="${var:logDir}/transcription-server.log"
            archiveFileName="${var:logDir}/archive/transcription-server.{#}.log"
            archiveEvery="Day"
            archiveNumbering="DateAndSequence"
            maxArchiveFiles="30"
            keepFileOpen="false"
            createDirs="true"
            layout="${var:layout}" />

    <target xsi:type="File"
            name="errors"
            fileName="${var:logDir}/transcription-server.errors.log"
            archiveFileName="${var:logDir}/archive/transcription-server.errors.{#}.log"
            archiveEvery="Day"
            archiveNumbering="DateAndSequence"
            maxArchiveFiles="30"
            keepFileOpen="false"
            createDirs="true"
            layout="${var:layout}" />
  </targets>

  <rules>
    <logger name="*" minlevel="Trace" writeTo="file" />
    <logger name="*" minlevel="Info" writeTo="console" />
    <logger name="*" minlevel="Error" writeTo="errors" />
  </rules>
</nlog>
