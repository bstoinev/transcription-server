{
  "Transcription": {
    // Download the selected Whisper model automatically when it is not found locally.
    "autoDownloadModel": true,
    // Resample all incoming session audio to this sample rate before VAD and transcription.
    "targetSampleRate": 16000,
    // Emit at most one provisional partial transcript per active utterance within this interval.
    "partialUpdateIntervalMs": 750,
    // Use up to this much recent utterance audio as the rolling context window for partial transcription.
    "partialWindowMs": 12000,
    // Do not emit a final transcript unless the detected speech portion reaches at least this duration.
    "minimumUtteranceMs": 1800,
    // Treat this much trailing silence as an utterance boundary.
    "endSilenceMs": 1000,
    // Force an utterance to close once it reaches this duration even if speech is still continuing.
    "maxUtteranceMs": 30000,
    // Include this much audio before detected speech when starting a new utterance buffer.
    "preRollMs": 500,
    // Keep this much audio after the last detected speech frame when finalizing an utterance.
    "postRollMs": 700,
    // Evaluate VAD on fixed-size frames of this duration.
    "vadFrameMs": 20,
    // RMS energy threshold used by the simple server-side VAD implementation.
    "vadEnergyThreshold": 0.015,
    // Enable GPU inference when the selected Whisper runtime supports it.
    "useGpu": true,
    // Allow the server to continue on CPU if GPU was requested but the CUDA runtime is unavailable.
    "allowCpuFallback": false,
    // GPU device index passed to Whisper when GPU inference is enabled.
    "gpuDevice": 0,
    // Enable Whisper flash attention support when available in the runtime.
    "useFlashAttention": false,
    // Force the live transcription language for all sessions.
    "language": "en",
    // Keep language detection disabled for the live pipeline.
    "enableLanguageDetection": false,
    // Base server-side technical prompt prepended before any per-session prompt text.
    "technicalPrompt": "",
    // Maximum number of characters of final transcript history retained as prompt context.
    "promptContextCharacters": 256,
    // Optional model directory or pinned ggml model file path. Leave empty to use the default models folder.
    "modelPath": ""
  }
}
