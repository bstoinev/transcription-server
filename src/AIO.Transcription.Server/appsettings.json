{
  "Transcription": {
    // Download the selected Whisper model automatically when it is not found locally.
    "autoDownloadModel": true,

    // Resample all incoming session audio to this sample rate before VAD and transcription.
    "targetSampleRate": 16000,

    // Emit at most one provisional partial transcript per active utterance within this interval.
    "partialUpdateIntervalMs": 1500,
    // Use up to this much recent utterance audio as the rolling context window for partial transcription.
    "partialWindowMs": 12000,

    // Do not emit a final transcript unless the detected speech portion reaches at least this duration.
    "minimumUtteranceMs": 700,
    // Treat this much trailing silence as an utterance boundary.
    "endSilenceMs": 1000,
    // Force an utterance to close once it reaches this duration even if speech is still continuing.
    "maxUtteranceMs": 30000,
    // Include this much audio before detected speech when starting a new utterance buffer.
    "preRollMs": 700,
    // Keep this much audio after the last detected speech frame when finalizing an utterance.
    "postRollMs": 800,

    // Evaluate VAD on fixed-size frames of this duration.
    "vadFrameMs": 20,
    // RMS energy threshold used by the simple server-side VAD implementation.
    "vadEnergyThreshold": 0.0035,
    // Keep only this much queued live audio before the worker; older queued chunks are discarded under pressure.
    "maxQueuedAudioBufferMs": 30000,

    // Master switch for live transcription diagnostic logs and optional debug WAV artifacts.
    "enableLiveDiagnostics": false,
    // Compact per-chunk logs after audio normalization.
    "logAudioChunkDiagnostics": false,
    // Very noisy frame-level VAD logs.
    "logVadFrameDiagnostics": false,
    // Utterance lifecycle logs for start, partials, endpointing, drops, finals, and emission.
    "logUtteranceDiagnostics": true,
    // Write utterance WAV/JSON artifacts for troubleshooting when diagnostics are enabled.
    "saveDebugUtteranceWavFiles": false,
    "debugUtteranceDirectory": "debug-audio",
    "saveDroppedUtterances": true,
    "saveFinalizedUtterances": true,
    "maxDebugUtteranceFilesPerSession": 100,

    "useGpu": true,
    "allowCpuFallback": false,
    "gpuDevice": 0,
    "useFlashAttention": true,

    "language": "en",
    "enableLanguageDetection": false,

    // Base server-side technical prompt prepended before any per-session prompt text.
    "technicalPrompt": "English technical meeting. Speakers may be non-native English speakers. Transcribe literally. Do not correct grammar. Technical terms may include .NET, ASP.NET Core, Azure, SQL Server, Docker, Kubernetes, API, OAuth, JWT, WebSocket, CI/CD, Redis, RabbitMQ, microservices, dependency injection, repository, deployment pipeline, pull request, repository, branch, commit, deployment, production, staging, database, cache, background service, hosted service.",
    "promptContextCharacters": 768,

    "modelPath": "M:\\whisper.cpp"
  }
}
